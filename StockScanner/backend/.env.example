# Postgres (separate scanner_db, mirrors PG_* convention used by trades_db)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DB=scanner_db

# Polygon (re-uses your existing key from env)
POLYGON_API_KEY=

# Path to the live scanner_v2 JSON state file
SCANNER_DATA_FILE=../scanner_v2/logs/scanner_data.json

# CORS origin for the Next.js frontend
FRONTEND_ORIGIN=http://localhost:3000

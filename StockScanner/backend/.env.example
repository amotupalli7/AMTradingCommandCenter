# Postgres (separate scanner_db, mirrors PG_* convention used by trades_db)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DB=scanner_db

# Polygon (re-uses your existing key from env)
POLYGON_API_KEY=

# Path to the live scanner_v2 JSON state file
SCANNER_DATA_FILE=../scanner_v2/logs/scanner_data.json

# CORS origin for the Next.js frontend
FRONTEND_ORIGIN=http://localhost:3000

# Local TCP trade gateway hosted by scanner_v2 (backend connects here for live
# trades instead of opening a second Polygon WS).
TRADE_GATEWAY_HOST=127.0.0.1
TRADE_GATEWAY_PORT=8765
# Seconds to wait before live_hub's first connect attempt. Scanner takes a
# moment to boot (snapshot + premarket bootstrap), so this avoids early
# "cannot connect" warnings when both processes start together.
LIVE_HUB_STARTUP_DELAY=15
